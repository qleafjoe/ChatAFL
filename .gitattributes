# Force LF line endings for script files on all platforms
*.sh text eol=lf
*.py text eol=lf
*.pl text eol=lf
*.rb text eol=lf
Makefile text eol=lf
*.mk text eol=lf

# Normalize text files
*.md text
*.txt text
*.mdwn text
*.json text
*.xml text
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.tar binary
*.gz binary
*.zip binary
